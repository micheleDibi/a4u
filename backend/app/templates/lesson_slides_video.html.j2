<!doctype html>
<html lang="{{ language }}">
<head>
  <meta charset="utf-8" />
  <title>{{ course.title }} — {{ lesson.title }} — Video slides</title>
  <style>
    /* Template video: ogni slide è renderizzata a PNG 1920x1080 via
       Playwright element.screenshot(). Differenze rispetto al template
       PDF (lesson_slides_pdf.html.j2):
         - tutto in px (no mm), viewport 1920x1080 fisso
         - niente @page rules, niente page-break (PDF-only)
         - niente footer/page-counter (lo studente non li vede in video)
         - margini più generosi per leggibilità a distanza
       Il rendering Playwright applica device-scale-factor=1 → PNG 1:1px. */
    *, *::before, *::after { box-sizing: border-box; }
    html, body {
      margin: 0;
      padding: 0;
      background: transparent;
      font-family: "{{ tpl.font_family }}", "Inter", "Helvetica", "Arial",
                   sans-serif;
      color: {{ tpl.text_color }};
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }

    .slide {
      position: relative;
      width: 1920px;
      height: 1080px;
      overflow: hidden;
      background: #ffffff;
    }

    {% if tpl.background_image_url %}
    .slide-bg {
      position: absolute; inset: 0;
      background-image: url("{{ tpl.background_image_url }}");
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: {{ ((tpl.background_opacity_pct or 100) / 100.0) | round(3) }};
      z-index: 0;
    }
    {% else %}
    .slide-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(135deg,
          #ffffff 0%,
          {{ tpl.primary_color }}0c 55%,
          {{ tpl.secondary_color }}18 100%);
      background-color: #fafafa;
      z-index: 0;
    }
    {% endif %}

    .slide-header {
      position: absolute;
      top: 60px;
      left: 110px;
      right: 110px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 50px;
      z-index: 5;
    }
    .slide-header .logo-left,
    .slide-header .logo-right {
      max-height: 90px;
      max-width: 280px;
      object-fit: contain;
    }
    .slide-header .logo-spacer {
      visibility: hidden;
      width: 1px;
      height: 1px;
    }

    .slide-body {
      position: absolute;
      left: 110px;
      right: 110px;
      top: 220px;
      bottom: 160px;
      overflow: hidden;
      z-index: 2;
      display: flex;
      flex-direction: column;
    }
    .slide-tag {
      font-size: 22px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: {{ tpl.primary_color }};
    }
    .slide-title {
      margin: 18px 0 0;
      font-size: 80px;
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.01em;
      color: {{ tpl.text_color }};
    }
    .slide-body-text {
      margin: 28px 0 0;
      font-size: 34px;
      line-height: 1.4;
      font-weight: 400;
      opacity: 0.82;
      color: {{ tpl.text_color }};
      max-width: 1500px;
    }
    .slide-bullets {
      margin: 30px 0 0;
      padding: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }
    .slide-bullets li {
      display: flex;
      align-items: flex-start;
      gap: 24px;
      font-size: 32px;
      line-height: 1.35;
      opacity: 0.9;
      color: {{ tpl.text_color }};
    }
    .slide-bullets li::before {
      content: "";
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      margin-top: 14px;
      border-radius: 50%;
      background: linear-gradient(135deg,
        {{ tpl.primary_color }},
        {{ tpl.secondary_color }});
    }

    .slide-assets {
      margin-top: 30px;
      flex: 1 1 auto;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .slide-asset {
      max-width: 100%;
      max-height: 100%;
      text-align: center;
    }
    .slide-asset figure {
      margin: 0;
      max-width: 100%;
    }
    .slide-asset .figure-body {
      max-width: 100%;
    }
    .slide-asset svg,
    .slide-asset img {
      display: block;
      margin: 0 auto;
      max-width: 100%;
      max-height: 600px;
      width: auto;
      height: auto;
      object-fit: contain;
    }
    .slide-asset table {
      width: 100%;
      border-collapse: collapse;
      font-size: 24px;
    }
    .slide-asset th, .slide-asset td {
      border: 1px solid #ccc;
      padding: 8px 12px;
      text-align: left;
      word-wrap: break-word;
    }
    .slide-asset figcaption {
      font-size: 22px;
      font-style: italic;
      opacity: 0.7;
      margin-top: 12px;
      text-align: center;
    }
    .slide-asset .uploaded-image {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      display: block;
      margin: 0 auto;
    }

    .slide-footer {
      position: absolute;
      left: 110px;
      right: 110px;
      bottom: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
      z-index: 5;
      font-size: 22px;
      color: {{ tpl.text_color }};
      opacity: 0.75;
    }
    .slide-footer .author-meta .org {
      font-weight: 600;
    }
    .slide-footer .author-meta .sep {
      opacity: 0.5;
      margin: 0 10px;
    }
    .slide-footer .author-meta .secondary {
      opacity: 0.7;
    }
  </style>
</head>
<body>
  {% for slide in slides %}
  <section class="slide" data-slide-id="{{ slide.slide_id }}">
    <div class="slide-bg"></div>

    <div class="slide-header">
      {% if tpl.logo_left_url %}
        <img class="logo-left" src="{{ tpl.logo_left_url }}" alt="" />
      {% else %}
        <span class="logo-spacer"></span>
      {% endif %}
      {% if tpl.logo_right_url %}
        <img class="logo-right" src="{{ tpl.logo_right_url }}" alt="" />
      {% else %}
        <span class="logo-spacer"></span>
      {% endif %}
    </div>

    <div class="slide-body">
      <div class="slide-tag">{{ lesson_label }}</div>
      <h1 class="slide-title">{{ slide.title }}</h1>

      {% if slide.body %}
      <p class="slide-body-text">{{ slide.body }}</p>
      {% endif %}

      {% if slide.bullets %}
      <ul class="slide-bullets">
        {% for b in slide.bullets %}
        <li>{{ b }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if slide.assets_html %}
      <div class="slide-assets">
        {% for asset_html in slide.assets_html %}
        <div class="slide-asset">{{ asset_html|safe }}</div>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <div class="slide-footer">
      <div class="author-meta">
        {% if organization_name %}
        <span class="org">{{ organization_name }}</span>
        <span class="sep">·</span>
        {% endif %}
        <span class="secondary">{{ course.title }}</span>
      </div>
      <div class="author-meta">
        <span class="secondary">{{ lesson.title }}</span>
      </div>
    </div>
  </section>
  {% endfor %}
</body>
</html>
