<!doctype html>
<html lang="{{ language }}">
<head>
  <meta charset="utf-8" />
  <title>{{ course.title }} — {{ lesson.title }} — Slide</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: "{{ tpl.font_family }}", "Inter", "Helvetica",
                    "Arial", sans-serif;
      color: {{ tpl.text_color }};
    }

    /* Pagina: full-bleed A4 landscape (297×210 mm). Nessun margine
       dell'@page: la "safe zone" è creata dal padding interno della
       slide, replicando il 6% / 5% della preview. */
    @page {
      size: A4 landscape;
      margin: 0;
    }

    /* Una slide = una pagina, occupa l'intero foglio. */
    .slide {
      position: relative;
      width: 297mm;
      height: 210mm;
      overflow: hidden;
      page-break-after: always;
    }
    .slide:last-child { page-break-after: auto; }

    /* Background: immagine full-bleed con opacità dal template,
       oppure gradient di default. Sotto al contenuto. */
    {% if tpl.background_image_url %}
    .slide-bg {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background-image: url("{{ tpl.background_image_url }}");
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      opacity: {{ ((tpl.background_opacity_pct or 100) / 100.0) | round(3) }};
      z-index: 0;
    }
    {% else %}
    .slide-bg {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        linear-gradient(135deg,
          #ffffff 0%,
          {{ tpl.primary_color }}0c 55%,
          {{ tpl.secondary_color }}18 100%);
      background-color: #fafafa;
      z-index: 0;
    }
    {% endif %}

    /* Header: logo sinistra + logo destra, top 5% (10mm),
       inset orizzontale 6% (≈18mm). */
    .slide-header {
      position: absolute;
      top: 10mm;
      left: 18mm;
      right: 18mm;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8mm;
      z-index: 5;
    }
    .slide-header .logo-left,
    .slide-header .logo-right {
      max-height: 14mm;
      max-width: 38mm;
      object-fit: contain;
    }
    .slide-header .logo-spacer {
      visibility: hidden;
      width: 1mm;
      height: 1mm;
    }

    /* Body container: inset sx/dx come la preview, top 40mm,
       bottom 62mm per RISERVARE il quadrante bottom-right da circa
       65×46mm dove andrà l'avatar (l'avatar verrà aggiunto in un
       secondo momento). Niente contenuto deve finire sotto l'avatar
       né sotto il footer.

       Layout interno: top-aligned (flex-start) e overflow-hidden, in
       modo che assets molto alti (es. mermaid generati con tanti nodi)
       NON sbordino verso l'alto (sopra il titolo) né verso il basso
       (sotto la slide / sopra l'avatar). */
    .slide-body {
      position: absolute;
      left: 18mm;
      right: 24mm;
      top: 40mm;
      bottom: 62mm;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      overflow: hidden;
      z-index: 2;
    }
    .slide-tag {
      font-size: 9pt;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: {{ tpl.primary_color }};
    }
    .slide-title {
      margin: 3mm 0 0;
      font-size: 28pt;
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.01em;
      color: {{ tpl.text_color }};
    }

    /* Bullet con dot a gradiente come nella preview. flex-shrink:0
       per evitare che si comprimano quando ci sono asset alti. */
    .slide-bullets {
      margin: 5mm 0 0;
      padding: 0;
      list-style: none;
      flex-shrink: 0;
    }
    .slide-bullets li {
      display: flex;
      align-items: flex-start;
      gap: 4mm;
      font-size: 11pt;
      line-height: 1.35;
      margin: 0 0 2.5mm;
      opacity: 0.88;
      color: {{ tpl.text_color }};
    }
    .slide-bullets li::before {
      content: "";
      flex-shrink: 0;
      width: 3mm;
      height: 3mm;
      margin-top: 1.3mm;
      border-radius: 50%;
      background: linear-gradient(135deg,
        {{ tpl.primary_color }},
        {{ tpl.secondary_color }});
    }

    /* Asset (diagrammi, formule, tabelle, esempi) sotto i bullet.
       `flex: 1 1 auto; min-height: 0` insieme a overflow:hidden sul
       body permettono al contenitore di vincolare l'altezza degli
       asset SVG/img/table senza sbordare. Il `max-height: 60mm`
       sugli asset visivi è il cap concreto: WeasyPrint scala l'SVG
       proporzionalmente entro questo box. */
    .slide-assets {
      flex: 1 1 auto;
      min-height: 0;
      margin-top: 4mm;
      display: flex;
      flex-direction: column;
      gap: 2mm;
      overflow: hidden;
    }
    .slide-asset {
      max-width: 100%;
      max-height: 70mm;
      text-align: center;
    }
    /* SVG di Mermaid: il backend (`_fit_svg_inline`) inietta
       width/height in mm calcolati dal viewBox, così WeasyPrint
       rispetta il box senza clip. I CSS qui sotto sono safety-net
       in caso il viewBox manchi (l'SVG si limita comunque al
       container). */
    .slide-asset svg {
      display: block;
      margin: 0 auto;
      max-width: 100%;
      max-height: 70mm;
    }
    .slide-asset img {
      display: block;
      margin: 0 auto;
      max-width: 100%;
      max-height: 70mm;
      width: auto;
      height: auto;
    }
    .slide-asset figure {
      margin: 0;
    }
    .slide-asset table {
      width: 100%;
      border-collapse: collapse;
      font-size: 8.5pt;
      table-layout: fixed;
    }
    .slide-asset th, .slide-asset td {
      border: 0.4pt solid #ccc;
      padding: 0.8mm 1.5mm;
      text-align: left;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    .slide-asset .caption {
      font-size: 8pt;
      font-style: italic;
      opacity: 0.7;
      margin-top: 1mm;
      text-align: center;
    }
    .slide-asset .placeholder {
      border: 0.5pt dashed #ccc;
      padding: 4mm;
      font-size: 9pt;
      color: #888;
      text-align: center;
      border-radius: 1mm;
    }

    /* Footer: linea sottile + organizzazione · corso, page counter dx.
       `right: 85mm` riserva la fascia bottom-right ~80mm per l'avatar
       (avatar largo ~65mm + 5mm di safety + 15mm di inset destro).
       Senza questa riserva, il page counter finirebbe sotto l'avatar. */
    .slide-footer {
      position: absolute;
      left: 18mm;
      right: 85mm;
      bottom: 10mm;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 6mm;
      z-index: 5;
    }
    .slide-footer .author-line {
      width: 42mm;
      height: 0.3mm;
      background: {{ tpl.text_color }};
      opacity: 0.3;
    }
    .slide-footer .author-meta {
      margin-top: 2.5mm;
      font-size: 9pt;
      color: {{ tpl.text_color }};
    }
    .slide-footer .author-meta .org {
      font-weight: 600;
    }
    .slide-footer .author-meta .sep {
      opacity: 0.6;
      margin: 0 1.5mm;
    }
    .slide-footer .author-meta .secondary {
      opacity: 0.7;
    }
    .slide-footer .page-counter {
      font-family: "Menlo", "Consolas", monospace;
      font-size: 9pt;
      letter-spacing: 0.06em;
      opacity: 0.55;
      white-space: nowrap;
      color: {{ tpl.text_color }};
    }

    math { font-size: 11pt; }
  </style>
</head>
<body>
  {% for slide in slides %}
  <div class="slide">
    <div class="slide-bg"></div>

    <div class="slide-header">
      {% if tpl.logo_left_url %}
        <img class="logo-left" src="{{ tpl.logo_left_url }}" alt="" />
      {% else %}
        <span class="logo-spacer"></span>
      {% endif %}
      {% if tpl.logo_right_url %}
        <img class="logo-right" src="{{ tpl.logo_right_url }}" alt="" />
      {% else %}
        <span class="logo-spacer"></span>
      {% endif %}
    </div>

    <div class="slide-body">
      <div class="slide-tag">{{ lesson_label }}</div>
      <h1 class="slide-title">{{ slide.title }}</h1>

      {% if slide.bullets %}
      <ul class="slide-bullets">
        {% for b in slide.bullets %}
        <li>{{ b }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {% if slide.assets_html %}
      <div class="slide-assets">
        {% for asset_html in slide.assets_html %}
        <div class="slide-asset">{{ asset_html|safe }}</div>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <div class="slide-footer">
      <div>
        <div class="author-line"></div>
        <div class="author-meta">
          {% if organization_name %}
          <span class="org">{{ organization_name }}</span>
          <span class="sep">·</span>
          {% endif %}
          <span class="secondary">{{ course.title }}</span>
          <span class="sep">·</span>
          <span class="secondary">{{ lesson.title }}</span>
        </div>
      </div>
      <div class="page-counter">
        {{ "%02d"|format(slide.slide_number) }} / {{ "%02d"|format(total_slides) }}
      </div>
    </div>
  </div>
  {% endfor %}
</body>
</html>
