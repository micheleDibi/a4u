<!doctype html>
<html lang="{{ language }}">
<head>
  <meta charset="utf-8" />
  <title>{{ course.title }} — {{ lesson.title }} — Slide</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: "{{ tpl.font_family }}", "Inter", "DejaVu Sans",
                    "Liberation Sans", sans-serif;
      color: {{ tpl.text_color }};
    }

    /* Pagina: A4 landscape per layout slide. Margine derivato dal
       template (`margin_mm`), con un floor di 8mm per garantire
       leggibilità anche con valori molto bassi. */
    {% set _m = (tpl.margin_mm or 20) %}
    {% set _m = (_m if _m >= 8 else 8) %}
    @page {
      size: A4 landscape;
      margin: {{ _m }}mm;
      {% if tpl.logo_left_url or tpl.logo_right_url %}
      @top-left {
        content: element(pageHeader);
      }
      {% endif %}
      @bottom-right {
        content: counter(page) " / " counter(pages);
        font-family: "{{ tpl.font_family }}", sans-serif;
        font-size: 9pt;
        color: {{ tpl.text_color }};
      }
      @bottom-left {
        content: "{{ course.title|e }} — {{ lesson.title|e }}";
        font-size: 9pt;
        color: {{ tpl.text_color }};
        opacity: 0.6;
      }
    }

    /* Background image: copre tutta la slide (sotto il contenuto). */
    {% if tpl.background_image_url %}
    .page-background {
      position: fixed;
      top: -{{ _m }}mm;
      bottom: -{{ _m }}mm;
      left: -{{ _m }}mm;
      right: -{{ _m }}mm;
      background-image: url("{{ tpl.background_image_url }}");
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      opacity: {{ ((tpl.background_opacity_pct or 0) / 100.0) | round(3) }};
      z-index: -100;
    }
    {% endif %}

    /* Header con logo: usato come `running()` element nel margin-box
       @top-left, così appare su ogni slide. */
    {% if tpl.logo_left_url or tpl.logo_right_url %}
    .page-header {
      position: running(pageHeader);
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-bottom: 2mm;
    }
    .page-header .logo-left {
      max-height: 14mm;
      max-width: 50mm;
    }
    .page-header .logo-right {
      max-height: 14mm;
      max-width: 50mm;
      margin-left: auto;
    }
    {% endif %}

    .slide {
      page-break-after: always;
      min-height: 16cm;
      display: flex;
      flex-direction: column;
    }
    .slide:last-child { page-break-after: auto; }

    .slide-header {
      border-bottom: 2px solid {{ tpl.primary_color }};
      padding-bottom: 0.4cm;
      margin-bottom: 0.6cm;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1cm;
    }
    .slide-title {
      font-size: 22pt;
      font-weight: 700;
      color: {{ tpl.primary_color }};
      margin: 0;
      flex: 1;
    }
    .slide-meta {
      font-size: 9pt;
      color: {{ tpl.text_color }};
      opacity: 0.6;
      white-space: nowrap;
    }
    .slide-meta .slide-type {
      display: inline-block;
      padding: 0.1cm 0.3cm;
      border-radius: 0.2cm;
      background: {{ tpl.secondary_color }};
      color: white;
      font-weight: 600;
      margin-right: 0.3cm;
    }

    .slide-body {
      flex: 1;
      font-size: 13pt;
      line-height: 1.55;
    }
    .slide-body ul {
      list-style: disc;
      padding-left: 0.8cm;
      margin: 0.2cm 0 0.6cm 0;
    }
    .slide-body li { margin-bottom: 0.3cm; }

    .slide-asset {
      margin: 0.4cm 0;
      max-width: 100%;
    }
    .slide-asset svg { max-width: 100%; height: auto; }
    .slide-asset img { max-width: 100%; height: auto; }
    .slide-asset table {
      width: 100%;
      border-collapse: collapse;
      font-size: 10pt;
    }
    .slide-asset th, .slide-asset td {
      border: 1px solid #ccc;
      padding: 0.15cm 0.3cm;
      text-align: left;
    }
    .slide-asset .caption {
      font-size: 9pt;
      font-style: italic;
      color: {{ tpl.text_color }};
      opacity: 0.7;
      margin-top: 0.2cm;
      text-align: center;
    }
    .slide-asset .placeholder {
      border: 1px dashed #ccc;
      padding: 0.5cm;
      font-size: 10pt;
      color: #888;
      text-align: center;
      border-radius: 0.2cm;
    }

    .slide-footer {
      margin-top: auto;
      padding-top: 0.5cm;
      border-top: 1px solid #e5e5e5;
      font-size: 9pt;
      font-style: italic;
      color: {{ tpl.text_color }};
      opacity: 0.7;
    }
    .slide-footer .label {
      font-style: normal;
      font-weight: 600;
      opacity: 1;
    }

    math { font-size: 13pt; }
  </style>
</head>
<body>
  {% if tpl.background_image_url %}
  <div class="page-background"></div>
  {% endif %}

  {% if tpl.logo_left_url or tpl.logo_right_url %}
  <div class="page-header">
    {% if tpl.logo_left_url %}
      <img class="logo-left" src="{{ tpl.logo_left_url }}" alt="" />
    {% endif %}
    {% if tpl.logo_right_url %}
      <img class="logo-right" src="{{ tpl.logo_right_url }}" alt="" />
    {% endif %}
  </div>
  {% endif %}

  {% for slide in slides %}
  <div class="slide">
    <div class="slide-header">
      <h1 class="slide-title">{{ slide.title }}</h1>
      <div class="slide-meta">
        <span class="slide-type">{{ slide.type_label }}</span>
        {{ slide.slide_number }} / {{ total_slides }}
      </div>
    </div>
    <div class="slide-body">
      {% if slide.bullets %}
      <ul>
        {% for b in slide.bullets %}
        <li>{{ b }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% for asset_html in slide.assets_html %}
      <div class="slide-asset">{{ asset_html|safe }}</div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</body>
</html>
