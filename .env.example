# Unico file di env condiviso tra docker-compose e backend FastAPI.

# === Postgres (servizio docker compose) ===
POSTGRES_USER=a4u
POSTGRES_PASSWORD=a4u_dev_password
POSTGRES_DB=a4u
POSTGRES_PORT=5432

# === Porte stack produzione (docker-compose.prod.yml) ===
# Frontend (nginx pubblico). Default: 80.
FRONTEND_PORT=80
# Backend FastAPI. Default: esposto solo su localhost del server
# (`127.0.0.1:8000`) — il traffico esterno passa via reverse proxy
# del frontend. Esempi alternativi:
#   BACKEND_PORT=8000           → esposto su tutte le interfacce
#   BACKEND_PORT=192.168.1.10:8000 → solo interfaccia LAN specifica
BACKEND_PORT=127.0.0.1:8000

# === Backend (FastAPI / pydantic-settings) ===
ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=console            # console | json (json in produzione)

DATABASE_URL=postgresql+asyncpg://a4u:a4u_dev_password@localhost:5432/a4u
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Sostituire con un valore casuale di almeno 32 byte (es. `openssl rand -hex 48`)
JWT_SECRET=change-me-please-use-a-real-secret-of-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

FRONTEND_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=
COOKIE_SECURE=false           # true in produzione (HTTPS)

UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=5
AVATAR_AUDIO_MAX_MB=10
# In dev locale, MiniMax deve poter raggiungere /uploads/... su questa URL.
# Per testare la generazione clip, esporre via ngrok e mettere qui l'URL pubblico.
PUBLIC_BASE_URL=http://localhost:8000

# === MiniMax (generazione clip video avatar) ===
# Lascia vuoto per disabilitare la generazione (i clip resteranno in stato pending).
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3
MINIMAX_CLIP_DURATION=6
MINIMAX_CLIP_RESOLUTION=1080P
MINIMAX_POLL_INTERVAL_SECONDS=10

# === OpenAI ===
# Lascia OPENAI_API_KEY vuota per disabilitare TUTTE le funzioni AI
# (traduzione i18n, summarization documenti, generazione architettura
# corso, lesson structure, lesson content). Tutto il resto resta
# pendente in stato `pending` finché non valorizzi la chiave.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Modelli per le diverse fasi (ognuna usa un setting separato):
OPENAI_MODEL=gpt-4o-mini                 # traduzione i18n (Completa con AI)
OPENAI_TRANSLATE_BATCH_SIZE=40
OPENAI_SUMMARIZE_MODEL=gpt-4o-mini       # summary documenti corso
OPENAI_SUMMARIZE_MAX_TOKENS=8000
OPENAI_MODULES_LESSONS_MODEL=gpt-5.5     # generazione architettura
OPENAI_ARCHITECTURE_MAX_TOKENS=8000      # alza a 16000 se "finish_reason=length"
OPENAI_ARCHITECTURE_REASONING_EFFORT=medium     # [minimal, low, medium, high]
OPENAI_LESSON_STRUCTURE_MODEL=gpt-5.5    # generazione struttura lezione
OPENAI_LESSON_STRUCTURE_MAX_TOKENS=16000
OPENAI_LESSON_STRUCTURE_REASONING_EFFORT=medium # [minimal, low, medium, high]
OPENAI_LESSON_CONTENT_MODEL=gpt-5.5      # generazione contenuto lezione
OPENAI_LESSON_CONTENT_MAX_TOKENS=32000
OPENAI_LESSON_CONTENT_REASONING_EFFORT=none     # [minimal, low, medium, high]
OPENAI_LESSON_SLIDES_MODEL=gpt-5.5       # generazione slide lezione (Fase 4)
OPENAI_LESSON_SLIDES_MAX_TOKENS=16000
OPENAI_LESSON_SLIDES_REASONING_EFFORT=none    # [minimal, low, medium, high]
OPENAI_LESSON_SPEECH_MODEL=gpt-5.5       # generazione discorso temporizzato (Fase 5)
OPENAI_LESSON_SPEECH_MAX_TOKENS=16000
OPENAI_LESSON_SPEECH_REASONING_EFFORT=none    # [minimal, low, medium, high]

# Note:
# - "gpt-5.5" è il default per le fasi reasoning-heavy del pipeline.
#   Se non hai accesso a quel modello, sostituisci con "gpt-4o" (più
#   economico ma meno preciso su prompt complessi) o "o1-mini".
# - I `*_max_tokens` sono budget di OUTPUT; i modelli reasoning consumano
#   parecchi token nel pensiero interno PRIMA di emettere JSON, quindi
#   non sono molto oltre la lunghezza visibile attesa.
# - `*_reasoning_effort` controlla quanto "pensa" il modello prima di
#   rispondere. Effetto su qualità e tempi:
#     minimal → output quasi immediato, niente reasoning (solo gpt-5.x).
#     low     → ~1-3s reasoning, qualità base.
#     medium  → ~5-15s reasoning, default consigliato.
#     high    → ~20-60s reasoning, massima qualità (default su contenuto
#               lezione perché il task è il più complesso del pipeline).
#   I modelli o1/o1-mini accettano solo [low, medium, high] (non minimal).
#   I modelli non-reasoning (gpt-4o, gpt-4o-mini) ignorano il parametro.

# === Parallelismo worker pipeline corso ===
# Quante lezioni vengono generate in parallelo per ogni fase. I default
# sono prudenti per non triggerare rate-limit OpenAI con tier free/1.
# Per corsi grandi (12+ CFU = 24-30 lezioni) e API key OpenAI tier 2+
# (alti TPM/RPM), alza questi valori per drasticamente ridurre i tempi.
#
# Tempo stimato per corso da 30 lezioni:
#   concurrency=3  → ~90-120 min  (default, sicuro)
#   concurrency=8  → ~30-45 min   (consigliato tier 2+)
#   concurrency=15 → ~15-25 min   (tier 3+, ma rischio 429 più alto)
COURSE_LESSON_STRUCTURE_MAX_CONCURRENCY=5
COURSE_LESSON_CONTENT_MAX_CONCURRENCY=3
COURSE_LESSON_SLIDES_MAX_CONCURRENCY=3
COURSE_LESSON_SPEECH_MAX_CONCURRENCY=3
COURSE_LESSON_PDF_MAX_CONCURRENCY=2
# Worker generazione video MP4 (Fase 6 §9). Il TTS gira su RunPod GPU;
# localmente restano slide-render (Playwright) ed encoding (ffmpeg).
# Default safe = 1 sulla VM 2-core.
COURSE_LESSON_VIDEO_MAX_CONCURRENCY=1

# Polling interval del worker (secondi).
COURSE_LESSON_STRUCTURE_POLL_INTERVAL_SECONDS=4
COURSE_LESSON_CONTENT_POLL_INTERVAL_SECONDS=4
COURSE_LESSON_SLIDES_POLL_INTERVAL_SECONDS=4
COURSE_LESSON_SPEECH_POLL_INTERVAL_SECONDS=4
COURSE_LESSON_PDF_POLL_INTERVAL_SECONDS=4
COURSE_LESSON_VIDEO_POLL_INTERVAL_SECONDS=4

# Auto-retry trasparente prima del fail terminale.
COURSE_LESSON_STRUCTURE_AUTO_RETRY_MAX=5
COURSE_LESSON_CONTENT_AUTO_RETRY_MAX=5
COURSE_LESSON_SLIDES_AUTO_RETRY_MAX=5
COURSE_LESSON_SPEECH_AUTO_RETRY_MAX=5
COURSE_LESSON_PDF_AUTO_RETRY_MAX=5
# Video: 3 retry sono sufficienti — i fail comuni (voice sample
# mancante, ffmpeg KO, job RunPod fallito) non sono recuperabili da
# soli, e ogni tentativo richiede minuti.
COURSE_LESSON_VIDEO_AUTO_RETRY_MAX=3

# === Generazione video MP4 (Fase 6 §9) ===
# Pre-condizione runtime: lezione con speech_status='approved' AND
# slides_status='approved' AND Avatar.audio_path popolato per l'utente
# assegnatario al corso AND servizio TTS RunPod configurato.
#
# TTS XTTS-v2 su RunPod Serverless GPU (vedi cartella `XTTS/` del repo).
# Lascia RUNPOD_API_KEY / RUNPOD_TTS_ENDPOINT_ID vuoti per disabilitare
# la generazione video.
RUNPOD_API_KEY=
RUNPOD_TTS_ENDPOINT_ID=
RUNPOD_BASE_URL=https://api.runpod.ai
RUNPOD_TTS_TIMEOUT_SECONDS=1800     # timeout job (assorbe il cold start)
RUNPOD_TTS_POLL_INTERVAL_SECONDS=3

# "Video con Avatar" (Fase 6b §9b) — lip-sync MuseTalk su RunPod GPU,
# sovrapposto al video MP4 della lezione. Stesso account RunPod del TTS
# (RUNPOD_API_KEY riusato), endpoint serverless dedicato a MuseTalk.
# Cloudflare R2 (S3-compatible) è lo storage di transito del job.
# Lascia questi vuoti per disabilitare il "Video con Avatar".
RUNPOD_MUSETALK_ENDPOINT_ID=
R2_ENDPOINT=                        # https://<account>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Overlay dell'avatar sul video: lato del quadrato come frazione della
# larghezza del video, e margine dai bordi in pixel.
AVATAR_VIDEO_OVERLAY_SCALE=0.24
AVATAR_VIDEO_OVERLAY_MARGIN=24
# Risoluzione (lato del quadrato) a cui a4u ridimensiona le clip avatar
# prima di passarle a MuseTalk. Le clip MiniMax sono 1080×1080: a quella
# risoluzione il lip-sync su RunPod sfora il tetto di 60 min. 640 = ok.
AVATAR_VIDEO_CLIP_RESOLUTION=640

# Encoding ffmpeg (richiede binario `ffmpeg` in PATH).
# Preset 1080p30 H.264 + AAC 192 kbps, CRF 23 (qualità tipo YouTube).
# Peso ~25 MB per 10 min di video.
VIDEO_RESOLUTION=1920x1080
VIDEO_FRAMERATE=30
VIDEO_AUDIO_BITRATE=192k
VIDEO_AUDIO_SAMPLE_RATE=48000
VIDEO_VIDEO_CODEC=libx264
VIDEO_CRF=23                  # 18=alta qualità, 28=compresso
VIDEO_PIXEL_FORMAT=yuv420p    # compat HTML5/QuickTime
LESSON_VIDEO_MAX_MB=500
FFMPEG_BINARY=ffmpeg          # path assoluto se non in PATH

# Bootstrap dell'admin di piattaforma alla prima migrazione/avvio.
# Se vuoti, nessun admin viene creato automaticamente.
BOOTSTRAP_ADMIN_EMAIL=admin@a4u.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FULL_NAME=Platform Admin

RATE_LIMIT_LOGIN_PER_MIN=5
LOGIN_LOCKOUT_THRESHOLD=10
LOGIN_LOCKOUT_MINUTES=15

# Opzionale: error monitoring
SENTRY_DSN=
